import math

class Solution:
    def getPermutation(self, n: int, k: int) -> str:
        # 1. Create a list of numbers to use: [1, 2, 3, ..., n]
        numbers = [str(i) for i in range(1, n + 1)]
        
        # 2. Precompute factorials or use math.factorial
        # We need (n-1)! to determine the block size
        
        # Adjust k to be 0-indexed for easier math
        k -= 1
        res = []
        
        for i in range(n, 0, -1):
            # Calculate the size of the blocks for the current position
            # Block size is (number of remaining elements - 1)!
            block_size = math.factorial(i - 1)
            
            # Find the index of the number to pick
            index = k // block_size
            
            # Append the chosen number to our result and remove it from the list
            res.append(numbers.pop(index))
            
            # Update k to find the position within the next block
            k %= block_size
            
        return "".join(res)
