class Solution:
    def groupAnagrams(self, strs: List[str]) -> List[List[str]]:
        res = defaultdict(list)
        for s in strs:
            count = [0] * 26
            for char in s:
                count[ord(char) - ord('a')] += 1
            # Use the tuple of counts as the dictionary key (it's hashable)
            res[tuple(count)].append(s)
        return list(res.values())
