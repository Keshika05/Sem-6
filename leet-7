class Solution:
    def totalNQueens(self, n: int) -> int:
        col = set()
        posDiag = set()  # (r + c)
        negDiag = set()  # (r - c)
        
        self.count = 0

        def backtrack(r):
            # Base case: All queens placed
            if r == n:
                self.count += 1
                return

            for c in range(n):
                # If the column or either diagonal is under attack, skip
                if c in col or (r + c) in posDiag or (r - c) in negDiag:
                    continue

                # Place queen and update sets
                col.add(c)
                posDiag.add(r + c)
                negDiag.add(r - c)

                # Move to the next row
                backtrack(r + 1)

                # Backtrack: Remove queen and clear sets for other branches
                col.remove(c)
                posDiag.remove(r + c)
                negDiag.remove(r - c)

        backtrack(0)
        return self.count
