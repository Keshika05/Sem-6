class Solution:
    def maxSubArray(self, nums: List[int]) -> int:
        # Initialize max_sum with the first element to handle single-element arrays
        max_sum = nums[0]
        current_sum = 0
        
        for n in nums:
            # If current_sum is negative, discard it and start fresh from n
            if current_sum < 0:
                current_sum = 0
            
            # Add current element to the current_sum
            current_sum += n
            
            # Update the global maximum
            max_sum = max(max_sum, current_sum)
            
        return max_sum
